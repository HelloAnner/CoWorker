# Optional. Leave empty when the frontend is served by the same origin as Coworker.
# Local dev uses the same relative paths through Vite proxy.
# Production same-origin deploy should also leave these empty.
# Example production split deployment:
# VITE_API_BASE_URL=https://coworker-api.example.com
# VITE_WS_BASE_URL=wss://coworker-api.example.com
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
